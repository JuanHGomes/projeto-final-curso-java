#!/bin/sh
M2_HOME="${M2_HOME:-$HOME/.m2}"
MVNW_REPOURL="https://repo.maven.apache.org/maven2"
MVNW_VERSION="3.9.9"
MVNW_HOME="$HOME/.m2/wrapper/dists/apache-maven-${MVNW_VERSION}"
MVNW_BIN="$MVNW_HOME/bin"

if [ ! -d "$MVNW_BIN" ]; then
  mkdir -p "$MVNW_HOME"
  curl -sL "$MVNW_REPOURL/org/apache/maven/apache-maven/${MVNW_VERSION}/apache-maven-${MVNW_VERSION}-bin.tar.gz" | tar xz -C "$MVNW_HOME" --strip-components=1 2>/dev/null
fi

exec "$MVNW_BIN/mvn" "$@"
